OnboardingScreen {
    align: center middle;
}

.hidden {
    display: none;
}

/* ── Outer shell ─────────────────────────────────────────── */

#onboarding-container {
    width: 78;
    height: 90%;
    max-height: 50;
    min-height: 20;
    border: round $primary;
    padding: 1 3 0 3;
    background: $panel;
    layout: vertical;
}

#title {
    text-align: center;
    text-style: bold;
    color: $primary;
    height: auto;
    margin-bottom: 0;
}

#subtitle {
    text-align: center;
    color: $text-muted;
    height: auto;
    margin-bottom: 1;
}

/* ── Shared pane wrapper ─────────────────────────────────── */

#onboarding-main {
    height: 1fr;
    min-height: 0;
}

/* Both panes fill the main area; only one is visible at a time */
#pane-step1,
#pane-step2 {
    height: 1fr;
    min-height: 0;
    layout: vertical;
}

/* ── Step 1 — provider list ──────────────────────────────── */

#provider-scroll {
    height: 1fr;
    min-height: 0;
    scrollbar-size-vertical: 1;
}

#recommendation {
    height: auto;
    margin-top: 1;
    color: $text-muted;
    text-style: italic;
}

/* ── Step 2 — config form ────────────────────────────────── */

#step2-heading {
    text-align: center;
    text-style: bold;
    color: $primary;
    height: auto;
    margin-bottom: 1;
}

#step2-form-scroll {
    height: 1fr;
    min-height: 0;
    scrollbar-size-vertical: 1;
    padding-right: 1;
}

/*
 * Every section inside the scroll MUST be height: auto so that
 * Textual can measure real content height and enable scrolling.
 * `Vertical` already sets height: auto but we force it here too.
 */
#api-key-section,
#base-url-section,
#remote-model-section,
#ollama-model-section {
    height: auto;
    display: none;
    margin-top: 1;
    margin-bottom: 1;
    padding: 0;
}

#api-key-section.visible,
#base-url-section.visible,
#remote-model-section.visible,
#ollama-model-section.visible {
    display: block;
}

/* Labels inside sections */
#api-key-label,
#base-url-label,
#remote-chat-label,
#remote-check-label,
#ollama-model-label,
#ollama-check-model-label {
    height: auto;
    margin-bottom: 1;
}

/* Inputs fill width and have fixed-height (Textual default is 3) */
#api-key-input,
#base-url-input,
#remote-chat-model-input,
#remote-check-model-input {
    width: 100%;
    margin-bottom: 1;
}

/* Select widgets */
#ollama-model-select,
#ollama-check-model-select {
    width: 100%;
    margin-bottom: 1;
}

#status-message {
    height: auto;
    margin-top: 1;
    margin-bottom: 1;
    color: $warning;
}

/* ── Footer buttons ──────────────────────────────────────── */

#button-row {
    height: 4;
    layout: horizontal;
    padding: 1 0 0 0;
    align-vertical: middle;
}

#btn-back {
    width: auto;
    min-width: 8;
    margin-right: 1;
}

#btn-continue {
    width: 1fr;
    margin-right: 1;
}

#btn-skip {
    width: 1fr;
}
